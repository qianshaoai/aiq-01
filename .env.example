# ─── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── 认证 ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── AI Key 加密主密钥 ──────────────────────────────────────────────────────────
ENCRYPTION_KEY="replace-with-32-byte-hex-string"

# ─── 应用 ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
