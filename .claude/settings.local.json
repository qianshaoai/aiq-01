{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(which node:*)",
      "Bash(npm install:*)",
      "Bash(pnpm:*)",
      "Bash(ls:*)",
      "Bash(which gh:*)",
      "Bash(gh repo:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(git push:*)",
      "Bash(cat:*)",
      "Bash(git pull:*)",
      "Bash(node:*)",
      "Bash(find:*)",
      "Bash(taskkill:*)",
      "Bash(cmd /c \"taskkill /PID 28396 /F & taskkill /IM node.exe /F & exit 0\")",
      "Bash(cmd /c \"tasklist | findstr node.exe\")",
      "Bash(powershell -Command \"Stop-Process -Id 28396 -Force -ErrorAction SilentlyContinue; Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep 1; Get-Process -Name node -ErrorAction SilentlyContinue | Select-Object Id,Name\")",
      "Bash(powershell -Command \"Get-Process node -ErrorAction SilentlyContinue | Select Id,Name,Path\")",
      "Bash(wmic process:*)",
      "Bash(netstat:*)",
      "Bash(cmd /c \"taskkill /PID 30128 /F 2>nul & taskkill /IM node.exe /F 2>nul & exit 0\")",
      "Bash(cmd /c \"taskkill /IM node.exe /F 2>nul & exit 0\")",
      "Bash(grep:*)",
      "Bash(curl:*)",
      "Bash(powershell -Command \"Invoke-WebRequest -Uri 'http://localhost:3000/manager/login' -UseBasicParsing | Select-Object -ExpandProperty StatusCode\" 2>&1)"
    ]
  }
}
